{
  "$schema": "../../../src/Application/yarp-config.schema.json",
  "StaticFiles": {
    "Enabled": true
  },
  "Redirects": [
    {
      "Match": { "Path": "/learn/{slug}" },
      "Destination": "/docs/{slug}.html",
      "StatusCode": 301
    }
  ],
  "Rewrites": [
    {
      "Regex": "^docs/current/(.*)$",
      "Replacement": "docs/v2/$1"
    }
  ],
  "Headers": [
    {
      "Match": { "Path": "/docs/{**catch-all}" },
      "Set": {
        "X-Docs-Site": "contoso-docs"
      }
    }
  ]
}

