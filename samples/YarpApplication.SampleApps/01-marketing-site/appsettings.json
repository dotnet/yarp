{
  "$schema": "../../../src/Application/yarp-config.schema.json",
  "StaticFiles": {
    "Enabled": true
  },
  "NavigationFallback": {
    "Path": "/index.html"
  },
  "Headers": [
    {
      "Match": { "Path": "/{**catch-all}" },
      "Set": {
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "Match": { "Path": "/assets/{**catch-all}" },
      "Set": {
        "Cache-Control": "public,max-age=31536000,immutable",
        "X-Site": "contoso-marketing"
      }
    }
  ]
}

